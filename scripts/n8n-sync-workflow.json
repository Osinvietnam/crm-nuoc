    {
      "parameters": {
        "jsCode": "// Map Supabase customer row → LarkBase fields\nconst items = $input.all();\nreturn items.map(item => {\n  const r = item.json;\n  const fields = {\n    'Họ tên':            r.ho_ten ?? '',\n    'SĐT':               r.sdt ?? '',\n    'SĐT khác':          r.sdt_khac ?? '',\n    'Email':             r.email ?? '',\n    'Mã KH':             r.ma_kh ?? '',\n    'Địa chỉ HĐ':        r.dia_chi_hd ?? '',\n    'Địa chỉ CT':        r.dia_chi_ct ?? '',\n    'Pipeline':          r.pipeline ?? 'Lead mới',\n    'Mức ưu tiên':       r.muc_uu_tien ?? '',\n    'Nguồn KH':          r.nguon_kh ?? '',\n    'Đối tác GT':        r.doi_tac_gt ?? '',\n    'Loại hình nhà':     r.loai_hinh_nha ?? '',\n    'Nguồn nước':        r.nguon_nuoc ?? '',\n    'Khu vực':           r.khu_vuc ?? '',\n    'Nội dung':          r.noi_dung ?? '',\n    'Báo giá':           r.bao_gia ?? 0,\n    'Người phụ trách':   r.profiles?.full_name ?? '',\n  };\n  if (r.ngay_lien_he_dau) fields['Ngày liên hệ đầu'] = new Date(r.ngay_lien_he_dau).getTime();\n  return {\n    json: {\n      supabase_id:    r.id,\n      lark_record_id: r.lark_record_id,\n      table_id:       'tbl56uB4wSaACzgm',\n      table_name:     'customers',\n      fields,\n    }\n  };\n});"
      },
      "id": "map-customers",
      "name": "Map customers → Lark fields",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [700, 100]
    },
    {
      "parameters": {
        "jsCode": "// Map Supabase B2C order → LarkBase fields (CONTRACTS table)\nconst items = $input.all();\nreturn items.map(item => {\n  const r = item.json;\n  const fields = {\n    'Mã HĐ':             r.ma_hd ?? '',\n    'Khách hàng':        r.customers?.ho_ten ?? '',\n    'SĐT':               r.customers?.sdt ?? '',\n    'Sản phẩm':          (r.san_pham ?? []).join(', '),\n    'Giá trị HĐ':        r.gia_tri_hd ?? 0,\n    'Khu vực':           r.khu_vuc ?? '',\n    'Trạng thái':        r.trang_thai ?? '',\n    'Địa chỉ CT':        r.dia_chi_ct ?? '',\n    'Ghi chú':           r.ghi_chu ?? '',\n    'Người phụ trách':   r.profiles?.full_name ?? '',\n  };\n  if (r.ngay_ky)       fields['Ngày ký']          = new Date(r.ngay_ky).getTime();\n  if (r.ngay_giao_dk)  fields['Ngày giao dự kiến']= new Date(r.ngay_giao_dk).getTime();\n  if (r.ngay_giao_thuc)fields['Ngày giao thực tế']= new Date(r.ngay_giao_thuc).getTime();\n  return {\n    json: {\n      supabase_id:    r.id,\n      lark_record_id: r.lark_record_id,\n      table_id:       'tbl2l6Z9vPaHfNHs',\n      table_name:     'orders',\n      fields,\n    }\n  };\n});"
      },
      "id": "map-b2c",
      "name": "Map B2C → Lark fields",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [700, 300]
    },
    {
      "parameters": {
        "jsCode": "// Map Supabase maintenance_construction → LarkBase CONSTRUCTION table\nconst items = $input.all();\nreturn items.map(item => {\n  const r = item.json;\n  const fields = {\n    'Khách hàng':      r.customers?.ho_ten ?? '',\n    'SĐT':             r.customers?.sdt ?? '',\n    'Địa chỉ':         r.customers?.dia_chi_ct ?? '',\n    'Sản phẩm':        r.san_pham ?? '',\n    'Khu vực':         r.khu_vuc ?? '',\n    'Trạng thái':      r.trang_thai ?? '',\n    'Ghi chú':         r.ghi_chu ?? '',\n    'KTV phụ trách':   r.profiles?.full_name ?? '',\n  };\n  if (r.ngay_can_cs)  fields['Ngày cần CS']   = new Date(r.ngay_can_cs).getTime();\n  if (r.ngay_het_bh)  fields['Ngày hết BH']   = new Date(r.ngay_het_bh).getTime();\n  return {\n    json: {\n      supabase_id:    r.id,\n      lark_record_id: r.lark_record_id,\n      table_id:       'tbl2XRs8cikrVZXL',\n      table_name:     'maintenance_construction',\n      fields,\n    }\n  };\n});"
      },
      "id": "map-construction",
      "name": "Map construction → Lark fields",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [700, 500]
    },
    {
      "parameters": {
        "jsCode": "// Map Supabase maintenance_periodic → LarkBase PERIODIC_SERVICE table\nconst items = $input.all();\nreturn items.map(item => {\n  const r = item.json;\n  const fields = {\n    'Khách hàng':        r.customers?.ho_ten ?? '',\n    'SĐT':               r.customers?.sdt ?? '',\n    'Địa chỉ':           r.customers?.dia_chi_ct ?? '',\n    'Sản phẩm đã lắp':  (r.san_pham_da_lap ?? []).join(', '),\n    'Chu kỳ (tháng)':   r.chu_ky ?? 6,\n    'Trạng thái':        r.trang_thai ?? '',\n    'Ghi chú':           r.ghi_chu ?? '',\n    'NV phụ trách':      r.profiles?.full_name ?? '',\n  };\n  if (r.lan_bd_gan_nhat) fields['Lần BĐ gần nhất'] = new Date(r.lan_bd_gan_nhat).getTime();\n  if (r.lan_bd_tiep_theo)fields['Lần BĐ tiếp theo'] = new Date(r.lan_bd_tiep_theo).getTime();\n  return {\n    json: {\n      supabase_id:    r.id,\n      lark_record_id: r.lark_record_id,\n      table_id:       'tbl6sFK3nDfFRtLN',\n      table_name:     'maintenance_periodic',\n      fields,\n    }\n  };\n});"
      },
      "id": "map-periodic",
      "name": "Map periodic → Lark fields",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [700, 700]
    },

