{
  "name": "CRM Nước — Supabase → LarkBase Nightly Sync",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 2 * * *" }]
        }
      },
      "id": "trigger-cron",
      "name": "Cron — 2AM Daily",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [0, 300]
    },
    {
      "parameters": {
        "jsCode": "// Tính window sync: 25 giờ để tránh bỏ lỡ nếu job chạy muộn\nconst now = new Date();\nconst since = new Date(now.getTime() - 25 * 60 * 60 * 1000).toISOString();\nreturn [{ json: { since, nowIso: now.toISOString() } }];"
      },
      "id": "calc-window",
      "name": "Tính sync window",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 300]
    },

    {
      "parameters": {
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/customers",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Prefer", "value": "return=representation" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "updated_at", "value": "=gte.{{ $('Tính sync window').item.json.since }}" },
            { "name": "select", "value": "id,lark_record_id,ho_ten,sdt,sdt_khac,email,ma_kh,dia_chi_hd,dia_chi_ct,pipeline,muc_uu_tien,nguon_kh,doi_tac_gt,loai_hinh_nha,nguon_nuoc,khu_vuc,noi_dung,ngay_lien_he_dau,bao_gia,updated_at,nguoi_phu_trach,profiles!nguoi_phu_trach(full_name)" },
            { "name": "limit", "value": "500" }
          ]
        },
        "options": {}
      },
      "id": "fetch-customers",
      "name": "Fetch customers Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 100]
    },
    {
      "parameters": {
